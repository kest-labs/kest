# Pure Scaffold Essentials
# Local development defaults to http://127.0.0.1:8025 in code, but you can
# uncomment NEXT_PUBLIC_API_URL below to override it explicitly.
NODE_ENV=production
NEXT_PUBLIC_API_URL=https://api.kest.dev
NEXT_PUBLIC_API_BASE_PATH=/v1
NEXT_PUBLIC_API_PROXY_PATH=/api/proxy
NEXT_PUBLIC_API_USE_PROXY=true
# Optional public app domain used when generating/copying invite links.
# NEXT_PUBLIC_APP_URL=https://kest.run
NEXT_PUBLIC_LOCAL_RUNNER_URL=http://127.0.0.1:8788
# NEXT_PUBLIC_DEBUG_API_ERRORS=true

# Optional
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_DEFAULT_LOCALE=zh-Hans
